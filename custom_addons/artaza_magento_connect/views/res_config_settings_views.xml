<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.magento.connect</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Magento Connect" string="Magento Connect" name="artaza_magento_connect">
                    <block title="Middleware (FastAPI)" name="magento_middleware">
                        <setting string="Conexión al middleware"
                                 help="API key para enviar contenido CMS a Magento vía el middleware FastAPI.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label string="URL del middleware" for="magento_middleware_base_url"
                                           class="col-lg-4 o_light_label"/>
                                    <field name="magento_middleware_base_url"
                                           placeholder="https://www.artaza.net/api/v1"/>
                                </div>
                                <div class="row">
                                    <label string="API key" for="magento_api_key"
                                           class="col-lg-4 o_light_label"/>
                                    <field name="magento_api_key" password="True"/>
                                </div>
                                <div class="row mt16">
                                    <button name="action_magento_test_connection" type="object"
                                            string="Probar conexión" class="btn-secondary"
                                            icon="fa-plug"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Sincronización de bodegas"
                                 help="Registra tus almacenes de Odoo en el middleware. Después relacionás cada bodega con un source de Magento en el panel del middleware.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <button name="action_magento_sync_warehouses" type="object"
                                            string="Sincronizar bodegas con Magento" class="btn-secondary"
                                            icon="fa-cubes"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Sincronización automática de stock (cron)"
                                 help="El cron interno de Odoo empuja el stock a Magento según esta frecuencia. No requiere crontab del sistema.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <field name="magento_cron_active"/>
                                    <label for="magento_cron_active" string="Activar sync automática de stock"/>
                                </div>
                                <div class="row">
                                    <label string="Frecuencia" for="magento_cron_interval_number"
                                           class="col-lg-4 o_light_label"/>
                                    <field name="magento_cron_interval_number" class="oe_inline"/>
                                    <field name="magento_cron_interval_type" class="oe_inline"/>
                                </div>
                                <div class="row">
                                    <label string="Productos por lote" for="magento_stock_batch_size"
                                           class="col-lg-4 o_light_label"/>
                                    <field name="magento_stock_batch_size" class="oe_inline"/>
                                </div>
                                <div class="row mt16">
                                    <button name="action_magento_resync_all_stock" type="object"
                                            string="Marcar todo para sincronizar" class="btn-secondary"
                                            icon="fa-refresh"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_magento_config_settings" model="ir.actions.act_window">
        <field name="name">Ajustes Magento Connect</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="context">{'module': 'artaza_magento_connect'}</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.magento.connect</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Magento Connect" string="Magento Connect" name="artaza_magento_connect">
                    <block title="Middleware (FastAPI)" name="magento_middleware">
                        <setting string="Conexión al middleware"
                                 help="Credenciales OAuth2/JWT para enviar contenido CMS a Magento vía FastAPI.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label string="URL del middleware" for="magento_middleware_base_url"
                                           class="col-lg-4 o_light_label"/>
                                    <field name="magento_middleware_base_url"
                                           placeholder="https://www.sebastianartaza.com/api/v1"/>
                                </div>
                                <div class="row">
                                    <label string="Client ID" for="magento_client_id"
                                           class="col-lg-4 o_light_label"/>
                                    <field name="magento_client_id" placeholder="odoo-cms"/>
                                </div>
                                <div class="row">
                                    <label string="Client Secret" for="magento_client_secret"
                                           class="col-lg-4 o_light_label"/>
                                    <field name="magento_client_secret" password="True"/>
                                </div>
                                <div class="row mt16">
                                    <button name="action_magento_test_connection" type="object"
                                            string="Probar conexión" class="btn-secondary"
                                            icon="fa-plug"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_magento_config_settings" model="ir.actions.act_window">
        <field name="name">Ajustes Magento Connect</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="context">{'module': 'artaza_magento_connect'}</field>
    </record>
</odoo>

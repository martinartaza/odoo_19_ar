<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_magento_negotiation" model="ir.ui.view">
        <field name="name">sale.order.form.magento.negotiation</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Button: send the negotiated adjustment to Magento (Magento orders only) -->
            <xpath expr="//header" position="inside">
                <button name="action_open_set_total_wizard" type="object"
                        string="Adjust total" class="btn-secondary"
                        invisible="not magento_order_id"/>
                <button name="action_magento_push_negotiation" type="object"
                        string="Send adjustment to Magento" class="btn-secondary"
                        invisible="not magento_order_id"/>
            </xpath>
            <!-- Magento order reference + adjustment reason, right under the customer -->
            <field name="partner_id" position="after">
                <field name="magento_order_id" readonly="1" invisible="not magento_order_id"/>
                <field name="magento_order_state" readonly="1" invisible="not magento_order_id"/>
                <field name="magento_adjustment_reason" invisible="not magento_order_id"/>
            </field>
        </field>
    </record>
</odoo>

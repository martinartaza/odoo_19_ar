<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cms_page_list" model="ir.ui.view">
        <field name="name">artaza.magento.cms.page.list</field>
        <field name="model">artaza.magento.cms.page</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="identifier"/>
                <field name="magento_id"/>
                <field name="sync_state" widget="badge"
                       decoration-success="sync_state == 'synced'"
                       decoration-warning="sync_state == 'pending'"
                       decoration-danger="sync_state == 'error'"/>
                <field name="last_sync"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_cms_page_form" model="ir.ui.view">
        <field name="name">artaza.magento.cms.page.form</field>
        <field name="model">artaza.magento.cms.page</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sync_now" type="object" string="Sync now"
                            class="btn-primary" icon="fa-refresh"/>
                    <field name="sync_state" widget="statusbar"
                           statusbar_visible="pending,synced,error"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Page title"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="identifier" placeholder="url-key-of-the-page"/>
                            <field name="active"/>
                            <field name="store_ids"/>
                            <field name="sort_order"/>
                            <field name="page_layout"/>
                        </group>
                        <group>
                            <field name="magento_id"/>
                            <field name="last_sync"/>
                            <field name="sync_error" invisible="sync_state != 'error'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content" name="content">
                            <field name="content_heading" placeholder="Heading..."/>
                            <field name="content" widget="html"/>
                        </page>
                        <page string="SEO" name="seo">
                            <group>
                                <field name="meta_title"/>
                                <field name="meta_keywords"/>
                                <field name="meta_description"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cms_page_search" model="ir.ui.view">
        <field name="name">artaza.magento.cms.page.search</field>
        <field name="model">artaza.magento.cms.page</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="identifier"/>
                <filter name="synced" string="Synced" domain="[('sync_state','=','synced')]"/>
                <filter name="errors" string="With error" domain="[('sync_state','=','error')]"/>
                <filter name="archived" string="Archived" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="action_cms_page" model="ir.actions.act_window">
        <field name="name">CMS Pages</field>
        <field name="res_model">artaza.magento.cms.page</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

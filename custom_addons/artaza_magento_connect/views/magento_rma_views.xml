<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_magento_rma_list" model="ir.ui.view">
        <field name="name">magento.rma.list</field>
        <field name="model">magento.rma</field>
        <field name="arch" type="xml">
            <list>
                <field name="magento_increment_id"/>
                <field name="magento_order_increment_id"/>
                <field name="partner_id"/>
                <field name="customer_email" optional="hide"/>
                <field name="rma_type"/>
                <field name="state" widget="badge"
                       decoration-info="state in ('requested','accepted','in_transit','inspection')"
                       decoration-success="state in ('approved','resolved_exchange','resolved_credit')"
                       decoration-danger="state in ('rejected','fraud','held','returned')"/>
                <field name="magento_status" optional="hide"/>
                <field name="magento_created_at"/>
            </list>
        </field>
    </record>

    <record id="view_magento_rma_form" model="ir.ui.view">
        <field name="name">magento.rma.form</field>
        <field name="model">magento.rma</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_accept" type="object" string="Accept"
                            class="btn-primary" invisible="state != 'requested'"/>
                    <button name="action_reject" type="object" string="Reject"
                            invisible="state != 'requested'"/>
                    <button name="action_receive" type="object" string="Received"
                            class="btn-primary" invisible="state != 'accepted'"/>
                    <button name="action_approve" type="object" string="Approve product"
                            class="btn-primary" invisible="state != 'inspection'"/>
                    <button name="action_fraud" type="object" string="Reject as fraud"
                            invisible="state != 'inspection'"/>
                    <button name="action_resolve_credit" type="object" string="Resolve: credit"
                            class="btn-primary" invisible="state != 'approved'"/>
                    <button name="action_resolve_exchange" type="object" string="Resolve: exchange"
                            invisible="state != 'approved'"/>
                    <button name="action_resolve_return" type="object" string="Return to customer"
                            invisible="state != 'fraud'"/>
                    <button name="action_resolve_hold" type="object" string="Hold"
                            invisible="state != 'fraud'"/>
                    <field name="state" widget="statusbar" readonly="1"
                           statusbar_visible="requested,accepted,inspection,approved,resolved_credit"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_order" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart"
                                invisible="not sale_order_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Sales Order</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="magento_increment_id" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="magento_order_increment_id"/>
                            <field name="sale_order_id"/>
                            <field name="partner_id"/>
                            <field name="customer_email"/>
                        </group>
                        <group>
                            <field name="rma_type"/>
                            <field name="magento_status"/>
                            <field name="reason_code"/>
                            <field name="magento_created_at"/>
                        </group>
                    </group>
                    <group string="Decision">
                        <field name="admin_message"
                               placeholder="Shown to the customer in Magento (e.g. rejection reason)"/>
                        <field name="inspection_note"
                               placeholder="Internal assessment on receipt"/>
                        <field name="resolution" readonly="1"/>
                        <field name="credit_amount"/>
                        <field name="coupon_code"/>
                        <field name="odoo_reference" placeholder="e.g. credit note number"/>
                    </group>
                    <notebook>
                        <page string="Items">
                            <field name="line_ids">
                                <list>
                                    <field name="sku"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="qty_requested"/>
                                </list>
                            </field>
                        </page>
                        <page string="Customer Note" invisible="not customer_note">
                            <field name="customer_note" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_magento_rma" model="ir.actions.act_window">
        <field name="name">Returns (RMA)</field>
        <field name="res_model">magento.rma</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No returns imported yet</p>
            <p>Returns requested by customers in Magento are imported here.
               Use "Import RMAs from Magento" in the settings, or enable the cron.</p>
        </field>
    </record>
</odoo>

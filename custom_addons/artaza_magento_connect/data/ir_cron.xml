<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- noupdate: no pisar la frecuencia/estado que el usuario configure en Ajustes -->
    <data noupdate="1">
        <record id="ir_cron_magento_stock_sync" model="ir.cron">
            <field name="name">Magento: sync stock</field>
            <field name="model_id" ref="product.model_product_product"/>
            <field name="state">code</field>
            <field name="code">model._cron_magento_sync_stock()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="False"/>
        </record>

        <record id="ir_cron_magento_pull_orders" model="ir.cron">
            <field name="name">Magento: import orders</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="state">code</field>
            <field name="code">model._cron_magento_pull_orders()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="False"/>
        </record>

        <record id="ir_cron_magento_pull_rmas" model="ir.cron">
            <field name="name">Magento: import RMAs</field>
            <field name="model_id" ref="model_magento_rma"/>
            <field name="state">code</field>
            <field name="code">model._cron_magento_pull_rmas()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="False"/>
        </record>
    </data>
</odoo>

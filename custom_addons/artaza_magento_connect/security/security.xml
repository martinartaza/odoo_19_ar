<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_magento_connect" model="ir.module.category">
        <field name="name">Magento Connect</field>
        <field name="sequence">20</field>
    </record>

    <record id="privilege_magento_connect" model="res.groups.privilege">
        <field name="name">Magento Connect</field>
        <field name="category_id" ref="module_category_magento_connect"/>
        <field name="sequence">20</field>
    </record>

    <record id="group_magento_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_magento_connect"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_magento_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="privilege_magento_connect"/>
        <field name="implied_ids" eval="[(4, ref('group_magento_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
